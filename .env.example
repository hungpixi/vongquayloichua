# =========================================================================
# VÒNG QUAY LỜI CHÚA - LOCAL ENVIRONMENT CONFIGURATION
# =========================================================================

# -------------------------------------------------------------------------
# 1. Supabase Configuration (Frontend & Edge Functions)
# -------------------------------------------------------------------------
# Địa chỉ URL của dự án Supabase (Cần cho client và deploy)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
# API key công khai (Anonymous Key) dùng ở client
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
# API key quản trị (Service Role Key) - BẮT BUỘC dùng cho Sync Worker ghi log hàng loạt
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# -------------------------------------------------------------------------
# 2. Upstash Redis Configuration (Asynchronous Write Queue)
# -------------------------------------------------------------------------
# Địa chỉ REST URL của Upstash Redis
UPSTASH_REDIS_REST_URL=https://your-database.upstash.io
# REST Token để xác thực kết nối ghi queue
UPSTASH_REDIS_REST_TOKEN=your-upstash-redis-token

# -------------------------------------------------------------------------
# 3. Security Secrets (Anti-Cheat Server-Controlled Spin)
# -------------------------------------------------------------------------
# Khóa bí mật dùng để ký HMAC cho kết quả quay thưởng trên Server
# Hãy đặt một chuỗi ký tự ngẫu nhiên dài và bảo mật
SERVER_SPIN_SECRET=your-secure-hmac-salt-key-here

# -------------------------------------------------------------------------
# 4. Cloudflare Integration (Deploy Workers & Cron Triggers)
# -------------------------------------------------------------------------
# API Token có quyền sửa đổi Workers, KV, D1 trong tài khoản Cloudflare của bạn
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
# ID tài khoản Cloudflare
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
# ID Zone (tên miền) của Cloudflare (Không bắt buộc, dùng nếu trỏ custom domain)
CLOUDFLARE_ZONE_ID=your-cloudflare-zone-id

# -------------------------------------------------------------------------
# 5. Upstash QStash Configuration (Background Queue Sync Scheduler)
# -------------------------------------------------------------------------
# QStash Token dùng để trigger background sync API
QSTASH_TOKEN=your-upstash-qstash-token
# Secret token tự định nghĩa để bảo vệ endpoint sync-queue (Tránh bị spam)
CRON_SECRET=your-custom-cron-secret-key-here

